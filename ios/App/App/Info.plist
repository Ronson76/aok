<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
        <string>$(CAPACITOR_DEBUG)</string>
        <key>CFBundleDevelopmentRegion</key>
        <string>en</string>
        <key>CFBundleDisplayName</key>
        <string>aok</string>
        <key>CFBundleExecutable</key>
        <string>$(EXECUTABLE_NAME)</string>
        <key>CFBundleIdentifier</key>
        <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
        <key>CFBundleInfoDictionaryVersion</key>
        <string>6.0</string>
        <key>CFBundleName</key>
        <string>$(PRODUCT_NAME)</string>
        <key>CFBundlePackageType</key>
        <string>APPL</string>
        <key>CFBundleShortVersionString</key>
        <string>$(MARKETING_VERSION)</string>
        <key>CFBundleVersion</key>
        <string>$(CURRENT_PROJECT_VERSION)</string>
        <key>UILaunchStoryboardName</key>
        <string>LaunchScreen</string>
        <key>UIMainStoryboardFile</key>
        <string>Main</string>
        <key>UIRequiredDeviceCapabilities</key>
        <array>
                <string>arm64</string>
        </array>
        <key>UISupportedInterfaceOrientations</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationLandscapeLeft</string>
                <string>UIInterfaceOrientationLandscapeRight</string>
        </array>
        <key>UISupportedInterfaceOrientations~ipad</key>
        <array>
                <string>UIInterfaceOrientationPortrait</string>
                <string>UIInterfaceOrientationPortraitUpsideDown</string>
                <string>UIInterfaceOrientationLandscapeLeft</string>
                <string>UIInterfaceOrientationLandscapeRight</string>
        </array>
        <key>UIViewControllerBasedStatusBarAppearance</key>
        <true/>
        <key>NSLocationWhenInUseUsageDescription</key>
        <string>aok needs your location to share with emergency contacts when you trigger an alert or use GPS fitness tracking.</string>
        <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
        <string>aok needs background location access to track your GPS fitness routes and share your location during emergencies.</string>
        <key>NSLocationAlwaysUsageDescription</key>
        <string>aok needs background location access to track your GPS fitness routes and share your location during emergencies.</string>
        <key>NSMotionUsageDescription</key>
        <string>aok uses motion detection for Shake-to-SOS emergency alerts.</string>
        <key>NSCameraUsageDescription</key>
        <string>aok may use the camera for emergency recording features.</string>
        <key>NSMicrophoneUsageDescription</key>
        <string>aok may use the microphone for emergency recording and voice chat features.</string>
        <key>UIBackgroundModes</key>
        <array>
                <string>location</string>
                <string>fetch</string>
                <string>remote-notification</string>
                <string>audio</string>
                <string>processing</string>
        </array>
        <key>UIApplicationSupportsIndirectInputEvents</key>
        <true/>
        <key>UIApplicationSceneManifest</key>
        <dict>
                <key>UIApplicationSupportsMultipleScenes</key>
                <false/>
        </dict>
</dict>
</plist>
